# MusicTokenRing — plantilla para Vercel / importación manual
# Copia a vercel.env y rellena los valores. NO subas vercel.env a git.

# ==========================================
# SUPABASE
# ==========================================
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ==========================================
# BLOCKCHAIN - BASE NETWORK
# ==========================================
BASE_RPC_URL=https://mainnet.base.org
MTR_TOKEN_ADDRESS=0x99cd1eb32846c9027ed9cb8710066fa08791c33b
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# ==========================================
# PLATFORM WALLET
# ==========================================
PLATFORM_WALLET_ADDRESS=

# ==========================================
# ADMIN WALLET (claims; solo backend seguro)
# ==========================================
ADMIN_WALLET_ADDRESS=
ADMIN_WALLET_PRIVATE_KEY=

# ==========================================
# CREDITS SYSTEM
# ==========================================
MTR_TO_CREDIT_RATE=778

# ==========================================
# SERVER
# ==========================================
PORT=3001
NODE_ENV=production
