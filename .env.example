# MusicTokenRing — backend (Render). Copiar a variables de entorno; no commitear valores reales.
#
# Nombre exacto en Render: usa SUPABASE_SERVICE_ROLE_KEY (no "SUPABASE_SERVICE_ROLE").

# --- URL pública del API (IPN, CORS en widget-config, enlaces) ---
BACKEND_URL=https://musictoken-ring.onrender.com
# Alternativa en Render: RENDER_EXTERNAL_URL (se usa si BACKEND_URL no está)

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- RPC Base (juego, MTR, swaps; liquidación NOWPayments puede ser solo Tron) ---
BASE_RPC_URL=https://mainnet.base.org

# --- NOWPayments: API + IPN (webhook) ---
# IPN en dashboard: POST {BACKEND_URL}/webhook/nowpayments
# Firma: header x-nowpayments-sig = HMAC-SHA512(hex) del body crudo con NOWPAYMENTS_WEBHOOK_SECRET
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_WEBHOOK_SECRET=
CUSTODY_ENABLED=true

# Liquidación / wallet principal en el panel NOWPayments (ej. USDT TRC20 Tron):
PLATFORM_WALLET_ADDRESS=
# Opcional: si quieres separar en env (mismo valor que PLATFORM si solo usas una):
# NOWPAYMENTS_SETTLEMENT_ADDRESS=

# Si liquidación es Tron y NO usas wallet EVM para eso, no hace falta EVM_PLATFORM_WALLET_ADDRESS.
# Solo necesaria si activas listeners/swaps EVM (p. ej. ENABLE_LEGACY_CHAIN_DEPOSITS=true):
# EVM_PLATFORM_WALLET_ADDRESS=0x...

# Retiros de usuario y premios vía Custody (USDT TRC20 por defecto):
NOWPAYOUT_CURRENCY=USDTTRC20
# Si NOWPayments exige chain explícito para tu moneda, descomenta y ajusta:
# NOWPAYOUT_CHAIN=
# Forzar premios/retiros en USDC Base en lugar de TRC20:
# NOWPAYOUT_USE_USDC_BASE=true

# Importe mínimo pedido al usuario (USD). El servidor suma margen (buffers abajo) al llamar a NOWPayments.
NOWPAYMENTS_MIN_PAY_AMOUNT=1
# Margen sobre el USD enviado: evita "Crypto amount X is less than minimal" por el tipo de cambio.
NOWPAYMENTS_MIN_PAY_BUFFER_PCT=0.008
NOWPAYMENTS_MIN_PAY_BUFFER_USD=0.06
# Moneda de pago para POST /v1/payment (requerido por NOWPayments): usdttrc20, usdterc20, btc, etc.
NOWPAYMENTS_PAY_CURRENCY=usdttrc20

# Widget embebido (GET /api/public/nowpayments-widget-config usa la misma NOWPAYMENTS_API_KEY salvo override):
# NOWPAYMENTS_EMBED_PUBLIC_KEY=
# NOWPAYMENTS_EMBED_TYPE=donation-widget
# payment-widget solo si NOWPayments tiene habilitado el flujo comercial (si no, spinner infinito)
# NOWPAYMENTS_EMBED_CURRENCY=

# --- Admin (claims on-chain alternativos, operaciones backend) ---
ADMIN_WALLET_PRIVATE_KEY=
ADMIN_WALLET_ADDRESS=
VAULT_WALLET_ADDRESS=

# --- Premios: con CUSTODY_ENABLED=true + NOWPAYMENTS_API_KEY se usa createCustodyPayout (Tron/Base según NOWPAYOUT_*) ---
# Si Custody está off, premios MTR on-chain en Base requieren:
# PRIZE_SIGNER_PRIVATE_KEY=

# --- Legacy depósitos on-chain directos (desactivado por defecto) ---
# ENABLE_LEGACY_CHAIN_DEPOSITS=false

PORT=3001
NODE_ENV=production
