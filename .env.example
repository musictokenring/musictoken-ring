# MusicTokenRing — ejemplo de variables (sin secretos reales)

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- RPC Base (juego, MTR, vault EVM) ---
BASE_RPC_URL=https://mainnet.base.org

# --- NOWPayments (IPN + Custody) ---
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_WEBHOOK_SECRET=
CUSTODY_ENABLED=true

# Dirección de liquidación en el dashboard NOWPayments (p. ej. USDT TRC20 en Tron).
# Puede ser Tron (T…) o, si coinciden, una sola variable EVM:
PLATFORM_WALLET_ADDRESS=
# Opcional: si PLATFORM_WALLET_ADDRESS es solo Tron y necesitas swaps/listeners EVM:
# EVM_PLATFORM_WALLET_ADDRESS=0x...

NOWPAYOUT_CURRENCY=USDTTRC20
# NOWPAYOUT_CHAIN=  (solo si la API de NOWPayments lo exige para tu moneda)
# NOWPAYOUT_USE_USDC_BASE=true  (forzar USDC en Base en lugar de USDT TRC20)
NOWPAYMENTS_MIN_PAY_AMOUNT=0.01

# --- Admin / vault EVM (retiros on-chain alternativos) ---
ADMIN_WALLET_PRIVATE_KEY=
ADMIN_WALLET_ADDRESS=
VAULT_WALLET_ADDRESS=

# --- Opcional: premios on-chain MTR si NO usas Custody ---
# PRIZE_SIGNER_PRIVATE_KEY=

# --- Legacy depósitos on-chain (desactivado por defecto) ---
# ENABLE_LEGACY_CHAIN_DEPOSITS=false

PORT=3001
NODE_ENV=production
