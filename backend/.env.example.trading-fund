# Trading Fund Configuration
# ==========================
# 
# IMPORTANTE: Crear una nueva wallet para el trading fund
# Esta wallet solo recibe fees, nunca toca vault/apuestas
#
# Pasos:
# 1. Crear nueva wallet (MetaMask o similar)
# 2. Guardar private key de forma segura
# 3. Configurar dirección aquí
# 4. Asegurar que tenga ETH para gas

# Trading Fund Wallet (CREAR MANUALMENTE)
TRADING_FUND_WALLET=0x[TBD]

# Distribución de Fees (deben sumar 100%)
VAULT_FEE_PERCENTAGE=75        # 70-80% va al vault
TRADING_FUND_FEE_PERCENTAGE=25 # 20-30% va al trading fund

# Vault Wallet (ya existe)
VAULT_WALLET_ADDRESS=0x0000000000000000000000000000000000000001

# Fees Rates
DEPOSIT_FEE_RATE=0.05      # 5%
WITHDRAWAL_FEE_RATE=0.05  # 5%
BET_FEE_RATE=0.02         # 2%

# Base RPC (para transacciones)
BASE_RPC_URL=https://mainnet.base.org

# Admin Wallet (para firmar transacciones)
ADMIN_WALLET_PRIVATE_KEY=[TU_PRIVATE_KEY]
ADMIN_WALLET_ADDRESS=[TU_ADDRESS]
